### VITALS ###
# 节点主 API 监听端口
NODE_PORT=2222

# 面板密钥 (从 Remnawave Panel 获取)
SECRET_KEY=YOUR_SECRET_KEY_FROM_PANEL

### Internal (local) ports ###
# JS 兼容实现使用的 Xray API 端口 (内部使用，不要公开)
XTLS_API_PORT=61000

# Go 实现使用的本机 Internal REST 端口 (内部使用，不要公开)
# INTERNAL_REST_PORT=61001

### TLS client authentication ###
# Go 实现主 API 的 TLS 客户端证书策略:
# - mtls: 要求客户端证书
# - optional: 客户端证书可选
# - none: 不要求客户端证书，PaaS HTTPS 直连常用
# NODE_TLS_CLIENT_AUTH=mtls

### Xray assets ###
# Xray geoip.dat / geosite.dat 所在目录。
# 脚本安装默认是 ${RW_NODE_DIR}/share/xray，Go PaaS 镜像默认是 /usr/local/share/xray。
# XRAY_LOCATION_ASSET=/opt/rw-node/share/xray

### PaaS HTTP front ###
# PaaS 镜像默认启用 HAProxy HTTP 前置，用于 /xh-*、/ws-*、/node/*、/vision/* 路径分流。
# 标准 Docker 镜像和脚本安装通常不需要这些变量。
# PORT=3000
# HTTP_FRONT_ENABLED=true
# HTTP_FRONT_PORT=${PORT:-3000}
# XHTTP_UPSTREAM_PORT=8080
# WS_UPSTREAM_PORT=8880

# 工作目录通过安装时环境变量 RW_NODE_DIR 控制，默认 /opt/rw-node。
# PaaS JS 镜像内应用文件目录由 RW_NODE_APP_DIR 控制，默认 /opt/rw-node，通常不要修改。
