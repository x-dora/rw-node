# 外部环境变量优先级高于本文件中的同名变量。
# 复制为 .env 后可按需修改；真实 .env 不应提交到仓库。

NODE_PORT=2222
NODE_TLS_CLIENT_AUTH=none
INTERNAL_REST_PORT=61001
REQUIRE_SECRET_KEY=true
RW_NODE_DIR=
XRAY_LOCATION_ASSET=
HTTP_FRONT_PORT=3000
XHTTP_UPSTREAM_PORT=8080
WS_UPSTREAM_PORT=8880

# 可选：指定 rw-node-go release tag；留空时使用 GitHub latest release。
RW_NODE_GO_VERSION=

# 可选：指定已有 Caddy 二进制路径；设置后不会下载 Caddy。
CADDY_BIN=

# 可选：指定 Caddy release tag；留空时使用 GitHub latest release。
CADDY_VERSION=
